generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  operator_kecamatan
  operator_desa
  camat
}

enum TaskStatus {
  baru
  dikerjakan
  review
  selesai
  dibatalkan
}

enum TaskPriority {
  rendah
  sedang
  tinggi
  mendesak
}

enum TaskUpdateEventType {
  progress
  status_change
  submitted_review
  approved
  rejected
  cancelled
}

model Kabupaten {
  code      String      @id
  name      String
  kecamatan Kecamatan[]
  users     User[]
  tasks     Task[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Kecamatan {
  code          String    @id
  name          String
  kabupatenCode String
  kabupaten     Kabupaten @relation(fields: [kabupatenCode], references: [code])
  desa          Desa[]
  users         User[]
  tasks         Task[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([kabupatenCode])
}

model Desa {
  code          String     @id
  name          String
  kecamatanCode String
  kecamatan     Kecamatan  @relation(fields: [kecamatanCode], references: [code])
  users         User[]
  tasks         Task[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([kecamatanCode])
}

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  passwordHash  String
  name          String
  role          Role
  isActive      Boolean    @default(true)
  kabupatenCode String?
  kecamatanCode String?
  desaCode      String?
  kabupaten     Kabupaten? @relation(fields: [kabupatenCode], references: [code])
  kecamatan     Kecamatan? @relation(fields: [kecamatanCode], references: [code])
  desa          Desa?      @relation(fields: [desaCode], references: [code])
  createdTasks  Task[]     @relation("TaskCreator")
  assignedTasks Task[]     @relation("TaskAssignee")
  updates       TaskUpdate[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([role])
  @@index([kecamatanCode])
  @@index([desaCode])
}

model Task {
  id                   String            @id @default(cuid())
  title                String
  description          String?
  status               TaskStatus        @default(baru)
  priority             TaskPriority      @default(sedang)
  lastRejectionReason  String?
  submittedAt          DateTime?
  completedAt          DateTime?
  dueDate              DateTime?
  /// Shared id linking copies of the same multi-desa assignment (one Task row per desa).
  taskGroupId          String?
  kabupatenCode        String
  kecamatanCode        String
  desaCode             String?
  createdById          String
  assignedToId         String?
  kabupaten            Kabupaten         @relation(fields: [kabupatenCode], references: [code])
  kecamatan            Kecamatan         @relation(fields: [kecamatanCode], references: [code])
  desa                 Desa?             @relation(fields: [desaCode], references: [code])
  createdBy            User              @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo           User?             @relation("TaskAssignee", fields: [assignedToId], references: [id])
  attachments          TaskAttachment[]
  updates              TaskUpdate[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([status])
  @@index([priority])
  @@index([kabupatenCode])
  @@index([kecamatanCode])
  @@index([desaCode])
  @@index([taskGroupId])
  @@index([createdById])
  @@index([assignedToId])
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  fileName     String
  originalName String
  mimeType     String
  size         Int
  path         String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([taskId])
}

model TaskUpdate {
  id          String               @id @default(cuid())
  taskId      String
  authorId    String
  eventType   TaskUpdateEventType
  message     String?
  fromStatus  TaskStatus?
  toStatus    TaskStatus?
  task        Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User                 @relation(fields: [authorId], references: [id])
  attachments TaskUpdateAttachment[]
  createdAt   DateTime             @default(now())

  @@index([taskId])
  @@index([authorId])
  @@index([eventType])
}

model TaskUpdateAttachment {
  id           String     @id @default(cuid())
  updateId     String
  fileName     String
  originalName String
  mimeType     String
  size         Int
  path         String
  update       TaskUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([updateId])
}
