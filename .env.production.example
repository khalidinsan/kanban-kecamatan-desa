# Production env for https://sikilat.site
# Rename/copy to `.env` in Application Root on the server:
#   /var/www/vhosts/sikilat.site/httpdocs/.env
#
# Or paste the same keys into Plesk → Node.js → Custom environment variables.

# SQLite path is relative to the prisma/ folder (creates prisma/prod.db)
DATABASE_URL="file:./prod.db"

# Generate: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-secret-acak-dari-openssl"

# Must match the public HTTPS URL (no trailing slash)
AUTH_URL="https://sikilat.site"

NODE_ENV="production"
